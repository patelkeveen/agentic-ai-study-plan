# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit real keys to this public repo.

# Gemini API key from https://aistudio.google.com/apikey
# langchain-google-genai reads this automatically
GOOGLE_API_KEY=your-gemini-key-here

# Optional fallback (https://console.groq.com/)
# GROQ_API_KEY=

# Added on later days as needed:
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# LANGFUSE_SECRET_KEY=
